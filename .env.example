# Neon Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 64-hex-char (32-byte) secret used to sign session cookies
SESSION_SECRET=""

# 64-hex-char (32-byte) key used for AES-256-GCM message encryption
ENCRYPTION_KEY=""

# Gmail account used as the SMTP sender (e.g. you@gmail.com)
GMAIL_USER=""

# Gmail App Password — generate at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Google account)
GMAIL_APP_PASSWORD=""

# Bearer token Vercel Cron must present to /api/cron/dispatch
CRON_SECRET=""

# Public base URL used in magic-link and check-in emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"
